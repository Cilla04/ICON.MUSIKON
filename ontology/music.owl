      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#MellowAcoustic">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#LowEnergy"/>
        <rdf:Description rdf:about="#Acoustic"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#TenseTrack">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#LowValence"/>
        <rdf:Description rdf:about="#HighEnergy"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#ChillTrack">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#HighValence"/>
        <rdf:Description rdf:about="#LowEnergy"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#IntenseVocal">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#HighEnergy"/>
        <rdf:Description rdf:about="#Vocal"/>
        <rdf:Description rdf:about="#Electronic"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#AcousticSlow">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Acoustic"/>
        <rdf:Description rdf:about="#SlowTempo"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>


</rdf:RDF>
