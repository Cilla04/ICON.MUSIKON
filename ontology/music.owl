      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasDanceability"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.47</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#Acoustic">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
