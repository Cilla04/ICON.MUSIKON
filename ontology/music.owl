  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasNormTempo">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#MusicTrack"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasKey">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#MusicTrack"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#MusicTrack">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#MoodCategory">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#PlaylistMhe">
  <rdfs:subClassOf rdf:resource="#MoodCategory"/>
</owl:Class>

<owl:Class rdf:about="#PlaylistGoodVibes">
  <rdfs:subClassOf rdf:resource="#MoodCategory"/>
</owl:Class>

<owl:Class rdf:about="#PlaylistOldVibes">
  <rdfs:subClassOf rdf:resource="#MoodCategory"/>
</owl:Class>

<owl:Class rdf:about="#PlaylistAnime">
  <rdfs:subClassOf rdf:resource="#MoodCategory"/>
</owl:Class>

<owl:Class rdf:about="#PlaylistItalian">
  <rdfs:subClassOf rdf:resource="#MoodCategory"/>
</owl:Class>

<owl:Class rdf:about="#HighEnergy">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasEnergy"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.75</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#LowEnergy">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasEnergy"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.45</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#HighValence">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasValence"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.65</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#LowValence">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasValence"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.32</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#HighDanceability">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasDanceability"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.68</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#LowDanceability">
