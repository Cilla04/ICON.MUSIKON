  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasNormLoudness"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.4</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#FastTempo">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasNormTempo"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.55</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#SlowTempo">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasNormTempo"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.3</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#Speechy">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#MusicTrack"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasSpeechiness"/>
          <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.07</owl:hasValue>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#HappyTrack">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#HighValence"/>
        <rdf:Description rdf:about="#HighEnergy"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#SadTrack">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#LowValence"/>
        <rdf:Description rdf:about="#LowEnergy"/>
        <rdf:Description rdf:about="#Acoustic"/>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="#EnergeticDanceable">
  <rdfs:subClassOf rdf:resource="#MusicTrack"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#HighEnergy"/>
